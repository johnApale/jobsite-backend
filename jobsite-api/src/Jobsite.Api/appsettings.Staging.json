{
  "Logging": {
    "LogLevel": {
      "Default": "Information",
      "Microsoft.AspNetCore": "Warning",
      "Microsoft.EntityFrameworkCore": "Warning"
    }
  },
  "App": {
    "FileStorage": {
      "Provider": "S3"
    },
    "RateLimiting": {
      "GlobalRequestsPerMinute": 60,
      "AuthRequestsPerMinute": 5,
      "AiRequestsPerMinute": 10
    }
  }
}
